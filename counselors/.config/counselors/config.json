{
  "version": 1,
  "defaults": {
    "timeout": 540,
    "outputDir": "./agents/counselors",
    "readOnly": "bestEffort",
    "maxContextKb": 100,
    "maxParallel": 4
  },
  "tools": {
    "claude-opus": {
      "binary": "/home/void/.local/bin/claude",
      "adapter": "claude",
      "readOnly": {
        "level": "enforced"
      },
      "extraFlags": ["--model", "opus"]
    },
    "claude-sonnet": {
      "binary": "/home/void/.local/bin/claude",
      "adapter": "claude",
      "readOnly": {
        "level": "enforced"
      },
      "extraFlags": ["--model", "sonnet"]
    },
    "claude-haiku": {
      "binary": "/home/void/.local/bin/claude",
      "adapter": "claude",
      "readOnly": {
        "level": "enforced"
      },
      "extraFlags": ["--model", "haiku"]
    },
    "codex-5.3-xhigh": {
      "binary": "/usr/bin/codex",
      "adapter": "codex",
      "readOnly": {
        "level": "enforced"
      },
      "extraFlags": [
        "-m",
        "gpt-5.3-codex",
        "-c",
        "model_reasoning_effort=xhigh"
      ],
      "timeout": 900
    },
    "codex-5.3-high": {
      "binary": "/usr/bin/codex",
      "adapter": "codex",
      "readOnly": {
        "level": "enforced"
      },
      "extraFlags": ["-m", "gpt-5.3-codex", "-c", "model_reasoning_effort=high"]
    }
  },
  "groups": {
    "default": ["claude-opus", "codex-5.3-xhigh", "codex-5.3-high"],
    "quick": ["claude-opus", "codex-5.3-high"],
    "deep": ["claude-opus", "codex-5.3-xhigh", "codex-5.3-xhigh"],
    "claude": ["claude-opus", "claude-opus", "claude-sonnet", "claude-haiku"]
  }
}
