#!/bin/bash

# Omarchy theme-set hook: Sync Qt6 (Fusion) app colors with omarchy theme
# Generates a qt6ct color scheme from current omarchy theme colors,
# so apps like Kdenlive follow the light/dark theme switch.
# Note: Running Qt apps need a restart to pick up changes.

THEME_DIR="$HOME/.config/omarchy/current/theme"
QT6CT_COLORS_DIR="$HOME/.config/qt6ct/colors"
QT6CT_CONF="$HOME/.config/qt6ct/qt6ct.conf"
KDENLIVERC="$HOME/.config/kdenliverc"

# --- Color helpers ---

get_color() {
  grep "^$1 " "$THEME_DIR/colors.toml" | sed 's/.*"\(#[^"]*\)".*/\1/'
}

to_qt() { echo "#ff${1#\#}"; }

lighten() {
  local hex="${1#\#}" pct="$2"
  local r=$((16#${hex:0:2})) g=$((16#${hex:2:2})) b=$((16#${hex:4:2}))
  r=$((r + (255 - r) * pct / 100))
  g=$((g + (255 - g) * pct / 100))
  b=$((b + (255 - b) * pct / 100))
  printf "#ff%02x%02x%02x" "$r" "$g" "$b"
}

darken() {
  local hex="${1#\#}" pct="$2"
  local r=$((16#${hex:0:2})) g=$((16#${hex:2:2})) b=$((16#${hex:4:2}))
  r=$((r * (100 - pct) / 100))
  g=$((g * (100 - pct) / 100))
  b=$((b * (100 - pct) / 100))
  printf "#ff%02x%02x%02x" "$r" "$g" "$b"
}

contrast_text() {
  local hex="${1#\#}"
  local r=$((16#${hex:0:2})) g=$((16#${hex:2:2})) b=$((16#${hex:4:2}))
  local lum=$(( (r * 299 + g * 587 + b * 114) / 1000 ))
  if [ "$lum" -gt 128 ]; then echo "#ff000000"; else echo "#ffffffff"; fi
}

# --- Read theme colors ---

bg=$(get_color background)
fg=$(get_color foreground)
accent=$(get_color accent)
color5=$(get_color color5)

is_light=false
[ -f "$THEME_DIR/light.mode" ] && is_light=true

qt_bg=$(to_qt "$bg")
qt_fg=$(to_qt "$fg")
qt_accent=$(to_qt "$accent")

# --- Build QPalette ---
# WindowText, Button, Light, Midlight, Dark, Mid, Text, BrightText,
# ButtonText, Base, Window, Shadow, Highlight, HighlightedText,
# Link, LinkVisited, AlternateBase, ToolTipBase, ToolTipText,
# PlaceholderText, Accent

if $is_light; then
  qt_button=$(darken "$bg" 5)
  qt_light=$(lighten "$bg" 50)
  qt_midlight=$(lighten "$bg" 25)
  qt_dark=$(darken "$bg" 40)
  qt_mid=$(darken "$bg" 20)
  qt_base=$(lighten "$bg" 40)
  qt_altbase=$(darken "$bg" 3)
  qt_shadow=$(darken "$bg" 70)
  qt_placeholder=$(lighten "$fg" 40)
  dis_fg=$(lighten "$fg" 50)
else
  qt_button=$(lighten "$bg" 10)
  qt_light=$(lighten "$bg" 25)
  qt_midlight=$(lighten "$bg" 15)
  qt_dark=$(darken "$bg" 30)
  qt_mid=$(lighten "$bg" 5)
  qt_base=$(lighten "$bg" 5)
  qt_altbase=$(lighten "$bg" 8)
  qt_shadow=$(darken "$bg" 50)
  qt_placeholder=$(darken "$fg" 40)
  dis_fg=$(darken "$fg" 40)
fi

qt_bright="#ffffffff"
qt_highlight=$(to_qt "$accent")
qt_highlight_text=$(contrast_text "$accent")
qt_link=$(to_qt "$accent")
qt_link_visited=$(to_qt "${color5:-$accent}")
qt_tooltip_base=$(to_qt "$fg")
qt_tooltip_text=$(to_qt "$bg")

active="$qt_fg, $qt_button, $qt_light, $qt_midlight, $qt_dark, $qt_mid, $qt_fg, $qt_bright, $qt_fg, $qt_base, $qt_bg, $qt_shadow, $qt_highlight, $qt_highlight_text, $qt_link, $qt_link_visited, $qt_altbase, $qt_tooltip_base, $qt_tooltip_text, $qt_placeholder, $qt_accent"

disabled="$dis_fg, $qt_button, $qt_light, $qt_midlight, $qt_dark, $qt_mid, $dis_fg, $qt_bright, $dis_fg, $qt_base, $qt_bg, $qt_shadow, $qt_highlight, $qt_highlight_text, $qt_link, $qt_link_visited, $qt_altbase, $qt_tooltip_base, $qt_tooltip_text, $qt_placeholder, $qt_accent"

inactive="$active"

# --- Write qt6ct color scheme ---

mkdir -p "$QT6CT_COLORS_DIR"
cat > "$QT6CT_COLORS_DIR/omarchy.conf" << EOF
[ColorScheme]
active_colors=$active
disabled_colors=$disabled
inactive_colors=$inactive
EOF

# --- Update qt6ct.conf ---

if [ -f "$QT6CT_CONF" ]; then
  sed -i 's/^custom_palette=.*/custom_palette=true/' "$QT6CT_CONF"
  if grep -q '^color_scheme_path=' "$QT6CT_CONF"; then
    sed -i "s|^color_scheme_path=.*|color_scheme_path=$QT6CT_COLORS_DIR/omarchy.conf|" "$QT6CT_CONF"
  else
    sed -i "/^\[Appearance\]/a color_scheme_path=$QT6CT_COLORS_DIR/omarchy.conf" "$QT6CT_CONF"
  fi
fi

# --- Update Kdenlive ---

if [ -f "$KDENLIVERC" ]; then
  # Color scheme (light/dark)
  if $is_light; then
    sed -i 's/^ColorScheme=.*/ColorScheme=BreezeLight/' "$KDENLIVERC"
    sed -i 's/^ColorSchemePath=.*/ColorSchemePath=BreezeLight.colors/' "$KDENLIVERC"
  else
    sed -i 's/^ColorScheme=.*/ColorScheme=BreezeDark/' "$KDENLIVERC"
    sed -i 's/^ColorSchemePath=.*/ColorSchemePath=BreezeDark.colors/' "$KDENLIVERC"
  fi

  # Monitor background: neutral gray that matches the theme's lightness
  local_bg="${bg#\#}"
  bg_r=$((16#${local_bg:0:2})) bg_g=$((16#${local_bg:2:2})) bg_b=$((16#${local_bg:4:2}))
  lum=$(( (bg_r * 299 + bg_g * 587 + bg_b * 114) / 1000 ))
  # Slightly muted from the UI background so the video frame has an edge
  if $is_light; then
    gray=$(( lum * 90 / 100 ))
  else
    gray=$(( lum * 80 / 100 ))
  fi
  sed -i "s/^window_background=.*/window_background=$gray,$gray,$gray/" "$KDENLIVERC"
fi
